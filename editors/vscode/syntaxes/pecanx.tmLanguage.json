{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PecanX",
  "scopeName": "source.pecanx",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.pecanx",
          "begin": "--",
          "end": "$"
        },
        {
          "name": "comment.block.pecanx",
          "begin": "\\{-",
          "end": "-\\}",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.pecanx",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.pecanx", "match": "\\\\." },
        {
          "name": "meta.interpolation.pecanx",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.pecanx" } },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.pecanx" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "annotations": {
      "name": "storage.modifier.annotation.pecanx",
      "match": "@[A-Za-z_][A-Za-z0-9_]*"
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(module|import)\\b\\s+([A-Z][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.control.import.pecanx" },
            "2": { "name": "entity.name.namespace.pecanx" }
          }
        },
        {
          "match": "\\b(server\\s+fn|fn|parse)\\b\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.pecanx" },
            "2": { "name": "entity.name.function.pecanx" }
          }
        },
        {
          "match": "\\b(type\\s+alias|type|opaque)\\b\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.pecanx" },
            "2": { "name": "entity.name.type.pecanx" }
          }
        },
        {
          "match": "\\b(let!|let)\\b\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.let.pecanx" },
            "2": { "name": "variable.other.binding.pecanx" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.pecanx", "match": "\\b(if|then|else|match)\\b" },
        { "name": "keyword.other.pecanx", "match": "\\b(module|import|exposing|as|type|alias|opaque|parse|fn|server|let|effect)\\b" },
        { "name": "keyword.operator.word.pecanx", "match": "\\b(not|and|or)\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.pecanx", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.unit.pecanx", "match": "\\bunit\\b" },
        { "name": "support.constant.pecanx", "match": "\\b(Ok|Err|Some|None|NotAsked|Loading|Failure|Success)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.pecanx", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.pecanx", "match": "\\b[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.stdlib.pecanx",
          "match": "\\b(String|Int|Float|List|Dict|Option|Result|Char|Console|Html|Attr|Event|Cmd|Http|Time|Random|Nav|Server|Db|Decode|Json|Bool|Set|Program|Remote)\\b"
        },
        { "name": "entity.name.type.pecanx", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.call.pecanx" } }
        },
        {
          "match": "\\.([a-z_][A-Za-z0-9_]*)",
          "captures": { "1": { "name": "variable.other.member.pecanx" } }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.pipe.pecanx", "match": "\\|>" },
        { "name": "keyword.operator.arrow.pecanx", "match": "->" },
        { "name": "keyword.operator.cons.pecanx", "match": "::" },
        { "name": "keyword.operator.concat.pecanx", "match": "\\+\\+" },
        { "name": "keyword.operator.spread.pecanx", "match": "\\.\\.\\." },
        { "name": "keyword.operator.comparison.pecanx", "match": "(==|/=|<=|>=|<|>)" },
        { "name": "keyword.operator.try.pecanx", "match": "\\?" },
        { "name": "keyword.operator.arithmetic.pecanx", "match": "(\\+|-|\\*|/|%)" },
        { "name": "keyword.operator.assignment.pecanx", "match": "=" },
        { "name": "punctuation.separator.pipe.pecanx", "match": "\\|" }
      ]
    }
  }
}
